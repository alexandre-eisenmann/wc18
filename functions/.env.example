# Copy to .env in this folder (not committed; used by the emulator and for local dev).
# For production, use Google Cloud/Secret Manager or set legacy:
#   firebase functions:config:set stripe.secret_key="sk_live_..." stripe.webhook_secret="whsec_..."
#
# Secret key: only here or in server config — never in the frontend.
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# Stripe Dashboard → Webhooks → signing secret (required for the stripeWebhook endpoint)
STRIPE_WEBHOOK_SECRET=
